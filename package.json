{
  "name": "saferoute-ultimate",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:full": "./scripts/start-dev.sh",
    "build": "vite build",
    "preview": "vite preview",
    "dev:api": "bash scripts/start-api.sh",
    "lint": "node scripts/lint.mjs && npm run check:trust-copy",
    "check:trust-copy": "node scripts/check-trust-copy.mjs",
    "check:release-readiness": "node scripts/check-release-readiness.mjs",
    "check:public-beta": "npm run check:trust-copy && npm run check:release-readiness",
    "typecheck:backend": "pyright",
    "test:backend": "./venv/bin/python -m pytest -q",
    "test:e2e": "node scripts/e2e-smoke.mjs",
    "smoke:api": "bash scripts/smoke-api.sh",
    "smoke:self-hosted": "bash scripts/smoke-self-hosted.sh",
    "db:telemetry-schema": "bash scripts/apply-telemetry-schema.sh",
    "db:telemetry-check": "bash scripts/check-telemetry-schema.sh",
    "db:telemetry-report": "bash scripts/report-telemetry.sh",
    "db:migrate": "bash scripts/run-migrations.sh",
    "db:migration-status": "bash scripts/migration-status.sh",
    "db:migration-check": "bash scripts/check-migrations.sh",
    "db:graph-check": "bash scripts/check-graph-data.sh",
    "db:graph-source-check": "bash scripts/check-graph-source.sh",
    "db:graph-export": "bash scripts/data/export-safety-graph.sh",
    "db:graph-dump-check": "bash scripts/data/check-graph-dump.sh",
    "db:graph-restore": "bash scripts/data/restore-safety-graph.sh",
    "db:enrichment-check": "bash scripts/check-enrichment-schema.sh",
    "db:enrichment-import": "bash scripts/data/import-enrichment.sh",
    "db:enrichment-import:osm": "bash scripts/data/import-osm-enrichment.sh",
    "db:enrichment-import:surface": "OSM_ENRICHMENT_FACTORS=surface bash scripts/data/import-osm-enrichment.sh",
    "db:enrichment-import:sidewalk": "OSM_ENRICHMENT_FACTORS=sidewalk bash scripts/data/import-osm-enrichment.sh",
    "db:enrichment-import:lighting": "OSM_ENRICHMENT_FACTORS=lighting bash scripts/data/import-osm-enrichment.sh",
    "db:enrichment-import:slope": "OSM_ENRICHMENT_FACTORS=slope bash scripts/data/import-osm-enrichment.sh",
    "db:enrichment-import:curb-osm": "OSM_ADVANCED_FACTORS=curb bash scripts/data/import-osm-advanced-enrichment.sh",
    "db:enrichment-import:crossings-osm": "OSM_ADVANCED_FACTORS=crossings bash scripts/data/import-osm-advanced-enrichment.sh",
    "db:enrichment-import:advanced-osm": "bash scripts/data/import-osm-advanced-enrichment.sh",
    "db:enrichment-import:micromobility-zones": "bash scripts/data/import-micromobility-zones.sh",
    "db:traffic-import:measured": "bash scripts/data/import-measured-traffic.sh",
    "db:pedestrian-import:density": "bash scripts/data/import-pedestrian-density.sh",
    "db:enrichment-report": "bash scripts/report-enrichment.sh",
    "db:enrichment-advanced-report": "bash scripts/report-enrichment.sh",
    "bootstrap:graph": "bash scripts/data/import-safety-graph.sh",
    "bootstrap:fresh": "bash scripts/data/fresh-bootstrap.sh",
    "bootstrap:check": "bash scripts/bootstrap-check.sh",
    "self-hosted:preflight": "bash scripts/self-hosted-preflight.sh",
    "self-hosted:up": "docker compose up -d",
    "self-hosted:down": "docker compose down",
    "self-hosted:logs": "docker compose logs -f",
    "self-hosted:ps": "docker compose ps",
    "self-hosted:check": "npm run self-hosted:preflight && npm run smoke:self-hosted",
    "self-hosted:fresh-test": "bash scripts/data/fresh-bootstrap.sh",
    "self-hosted:fresh-restore-test": "bash scripts/data/fresh-bootstrap.sh",
    "bootstrap:self-hosted": "bash scripts/data/build-routing-stack.sh",
    "route:corpus-check": "bash scripts/check-route-corpus.sh",
    "perf:route-smoke": "bash scripts/perf-route-smoke.sh",
    "perf:telemetry-smoke": "bash scripts/perf-telemetry-smoke.sh",
    "release:graph:prepare": "bash scripts/data/prepare-graph-release.sh",
    "release:graph:check": "bash scripts/data/check-graph-release.sh",
    "release:graph:upload": "bash scripts/data/upload-graph-release.sh",
    "security:production-check": "bash scripts/check-production-security.sh",
    "check:backend": "npm run lint && npm run typecheck:backend && npm run test:backend",
    "check": "npm run lint && npm run test:backend && npm run build",
    "check:full": "npm run check && npm run smoke:api && npm run test:e2e"
  },
  "dependencies": {
    "framer-motion": "^10.16.4",
    "liquid-glass-react": "^1.1.1",
    "lucide-react": "^0.300.0",
    "maplibre-gl": "^3.6.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-map-gl": "^7.1.7"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "autoprefixer": "^10.4.16",
    "playwright": "^1.59.1",
    "postcss": "^8.4.31",
    "pyright": "^1.1.409",
    "tailwindcss": "^3.3.5",
    "vite": "^6.4.2"
  }
}
