MOSCOW_MIN_LAT=55.45
MOSCOW_MAX_LAT=56.02
MOSCOW_MIN_LON=37.10
MOSCOW_MAX_LON=38.05
ROUTE_CACHE_TTL_SECONDS=120
ROUTE_CACHE_MAX_ENTRIES=512
ROUTE_BUCKET_PRECISION=4
ROUTE_DATA_VERSION=moscow-oblast-v1
ROUTE_GRAPH_ALGORITHM=astar
HEALTH_ROUTE_READINESS=true
TELEMETRY_DEFAULT_H3_RESOLUTION=9
TELEMETRY_MAX_BATCH_SIZE=500
SIDEWALK_CELLS_LIMIT=5000
VALHALLA_TILE_URLS=file:///custom_files/osm/moscow-oblast.osm.pbf
