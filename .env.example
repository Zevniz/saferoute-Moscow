DATABASE_URL=postgresql://artem@localhost:5433/artem
PHOTON_URL=http://localhost:2322
VALHALLA_URL=http://localhost:8002
PUBLIC_PHOTON_URL=https://photon.komoot.io
PUBLIC_VALHALLA_URL=https://valhalla1.openstreetmap.de
ALLOW_PUBLIC_SERVICE_FALLBACK=false
HTTP_USER_AGENT=SafeRoute/2.1 (local self-hosted)
HTTP_RETRY_ATTEMPTS=2
HTTP_RETRY_BACKOFF_SECONDS=0.25
