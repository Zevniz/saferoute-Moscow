# SafeRoute production environment template.
# Do not put real secrets in this file. Store production keys in the target secret manager.

SAFEROUTE_ENV=production

# Require API keys for public routing/search/reverse, metrics, deep health,
# tiles, telemetry writes, and sidewalk-cell reads.
SAFEROUTE_REQUIRE_API_KEY=true
SAFEROUTE_API_KEYS=<set-in-secret-manager>

# Keep shallow health public for load balancers, but protect deep diagnostics.
SAFEROUTE_PROTECT_DEEP_HEALTH=true

# Application-level backstop limits. Keep edge/ingress limits too.
SAFEROUTE_RATE_LIMIT_ENABLED=true
SAFEROUTE_RATE_LIMIT_PER_MINUTE=120
SAFEROUTE_MAX_TELEMETRY_PAYLOAD_BYTES=262144

# Production self-hosted dependencies.
ALLOW_PUBLIC_SERVICE_FALLBACK=false
DATABASE_URL=postgresql://<user>:<password>@<host>:5432/<database>
PHOTON_URL=http://photon:2322
VALHALLA_URL=http://valhalla:8002

# Route graph version must match the published graph artifact manifest.
ROUTE_DATA_VERSION=moscow-network-v1

# Optional dynamic weather risk. Disabled unless production explicitly accepts
# Open-Meteo terms/attribution and wants live route-level weather scoring.
SAFEROUTE_WEATHER_ENABLED=false
SAFEROUTE_WEATHER_PROVIDER=open_meteo
SAFEROUTE_WEATHER_CACHE_TTL_SECONDS=900
SAFEROUTE_WEATHER_TIMEOUT_SECONDS=3.0
